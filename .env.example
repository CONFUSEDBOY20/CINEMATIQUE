# Copy this file to .env and fill in your Supabase credentials

# Supabase — find these in your project: Settings > API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Optionally expose the anon key to the frontend (Vite)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# JWT secret for session tokens (change in production!)
JWT_SECRET=cinematique_dev_secret_change_in_production

# Server port (optional)
PORT=5000
